# Build context hygiene — keep the image build fast and reproducible. The
# builder reinstalls node_modules and rebuilds .next from source, so never ship
# the host's copies into the context.

# Dependencies (reinstalled in the builder stage)
node_modules
**/node_modules
.pnp
.pnp.*

# Next.js build output (rebuilt in the builder stage)
.next
out
build

# VCS / tooling
.git
.gitignore
.github
.claude

# Docs (not needed at build/runtime)
docs
*.md

# Tests & coverage
coverage
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
vitest.config.ts

# Local env / secrets (DATABASE_URL etc. are injected by Railway at runtime)
.env
.env.*
!.env.example

# Editor / OS cruft
.vscode
.idea
.DS_Store
*.pem

# TypeScript incremental build state
*.tsbuildinfo
next-env.d.ts

# Railway's NIXPACKS config is unused under the image model
railway.json
